// --- SENSOR AND PIN DEFINITIONS ---
const int waterSensorPin = A0; 

const int buzzerPin = 8;     
const int blueLEDPin = 9;    
const int greenLEDPin = 10;  
const int yellowLEDPin = 11; 

// --- STANDARD WATER THRESHOLDS ---
// 0 is completely dry. Higher numbers mean more water.
const int dryThreshold = 40;  // Anything below 40 is considered completely dry air
const int lowWater = 100;     // Barely touching water
const int mediumWater = 400;  // Partially submerged
const int highWater = 800;    // Mostly/fully submerged (triggers your 1022 reading)

void setup() {
  Serial.begin(9600);
  
  pinMode(buzzerPin, OUTPUT);
  pinMode(blueLEDPin, OUTPUT);
  pinMode(greenLEDPin, OUTPUT);
  pinMode(yellowLEDPin, OUTPUT);
}

void loop() {
  int sensorValue = analogRead(waterSensorPin);
  
  Serial.print("Raw Sensor Value: ");
  Serial.print(sensorValue);

  // Turn everything OFF first at the start of each check
  digitalWrite(blueLEDPin, LOW);
  digitalWrite(greenLEDPin, LOW);
  digitalWrite(yellowLEDPin, LOW);
  digitalWrite(buzzerPin, LOW);

  // STANDARD LOGIC: Check for highest water levels first
  if (sensorValue >= highWater) {
    // DANGER LEVEL: High water detected
    digitalWrite(blueLEDPin, HIGH);
    digitalWrite(greenLEDPin, HIGH);
    digitalWrite(yellowLEDPin, HIGH);
    digitalWrite(buzzerPin, HIGH);
    Serial.println(" -> STATUS: HIGH WATER ALARM!");
  } 
  else if (sensorValue >= mediumWater) {
    // WARNING LEVEL 
    digitalWrite(blueLEDPin, HIGH);
    digitalWrite(greenLEDPin, HIGH);
    Serial.println(" -> STATUS: Medium Water");
  } 
  else if (sensorValue >= lowWater) {
    // CAUTION LEVEL 
    digitalWrite(blueLEDPin, HIGH);
    Serial.println(" -> STATUS: Low Water Detected");
  }
  else if (sensorValue <= dryThreshold) {
    // DRY AIR: Everything stays OFF
    Serial.println(" -> STATUS: Dry (No water)");
  } 
  else {
    // Catch-all for slight dampness between 40 and 100
    Serial.println(" -> STATUS: Slightly Damp / Air Moisture");
  }

  delay(500); 
}
